# ====================================================================
# ReGender-XYZ Environment Configuration
# ====================================================================
# Copy this file to .env and add your API keys
#
# Supports three providers:
# - Anthropic/Claude (recommended — claude-opus-4-6, claude-sonnet-4-6)
# - OpenAI (gpt-4o, gpt-4o-mini)
# - Ollama  (local models, no API key required)
# ====================================================================

# ====================================================================
# API KEYS
# ====================================================================

# Anthropic/Claude Configuration (recommended)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here


# ====================================================================
# MODEL SELECTION
# ====================================================================

# Anthropic/Claude Models
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI Models
# Options: gpt-4o, gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Ollama (local) — set model name and optional custom endpoint
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ====================================================================
# PROVIDER CONFIGURATION
# ====================================================================

# Default Provider
# Options: anthropic, openai, ollama
DEFAULT_PROVIDER=anthropic

# ====================================================================
# QUALITY SETTINGS
# ====================================================================

# Character Analysis Quality
# Options: flagship (best available model), standard
CHARACTER_ANALYSIS_QUALITY=flagship

# ====================================================================
# CACHING AND PERFORMANCE
# ====================================================================

ENABLE_CACHE=true
CACHE_DIR=.cache
CACHE_TTL_HOURS=24
API_TIMEOUT=300
MAX_RETRIES=3

# ====================================================================
# DEVELOPMENT SETTINGS
# ====================================================================

DEBUG=false
LOG_DIR=logs
